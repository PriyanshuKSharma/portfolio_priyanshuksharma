<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Modern portfolio showcasing full-stack development skills">
  <link rel="icon" type="image/png" href="images/image.png">
  <title> Priyanshu Kumar Sharma | Portfolio</title>
  <!-- <%= title %>  -->
  <link rel="stylesheet" href="css/style.css?v=4.2">
  <link rel="stylesheet" href="css/theme.css">
  <link rel="stylesheet" href="css/chatbot.css?v=3.1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="loading-overlay">
    <div class="cyber-grid"></div>
    <div class="loading-content">
      <div class="scanner-line"></div>
      <div class="system-status">
        <div class="status-header">SYSTEM BOOT SEQUENCE</div>
        <div class="status-log" id="boot-log">
          <div>> INITIALIZING KERNEL...</div>
          <div>> LOADING MODULES...</div>
          <div>> VERIFYING SECURITY PROTOCOLS...</div>
        </div>
      </div>
      <div class="loader-ring">
        <div class="ring-inner"></div>
        <div class="ring-core"></div>
      </div>
      <div class="loading-bar-container">
        <div class="loading-bar-cyber"></div>
        <div class="loading-percentage">0%</div>
      </div>
      <div class="access-text">ACCESSING MAINFRAME</div>
    </div>
  </div>
  <div class="scroll-indicator"></div>
  <div class="social-sidebar" id="socialSidebar">
    <div class="social-controls">
      <button
        class="social-toggle"
        type="button"
        onclick="toggleSocialSidebar()"
        title="Toggle Social Links"
        aria-label="Toggle Social Links"
      >
        <span aria-hidden="true"><i class="fa-solid fa-share-nodes"></i></span>
      </button>
      <button
        class="social-toggle social-action-btn social-theme-trigger"
        type="button"
        title="Toggle Theme"
        aria-label="Toggle Theme"
      >
        <span aria-hidden="true"><i class="fa-solid fa-circle-half-stroke"></i></span>
      </button>
      <button
        class="social-toggle social-action-btn social-chat-trigger"
        type="button"
        title="Open Chatbot"
        aria-label="Open Chatbot"
        data-chatbot-trigger
      >
        <span aria-hidden="true"><i class="fa-solid fa-robot"></i></span>
      </button>
    </div>
    <div class="social-content">
      <div class="social-line"></div>
      <div class="social-icons-innovative">
        <a href="https://www.linkedin.com/in/priyanshu-kumar-sharma-333800251/" class="social-icon-circle" target="_blank" title="LinkedIn">
          <img src="https://img.icons8.com/color/24/linkedin.png" alt="LinkedIn">
        </a>
        <a href="https://github.com/PriyanshuKSharma" class="social-icon-circle" target="_blank" title="GitHub">
          <img src="https://img.icons8.com/color/24/github.png" alt="GitHub">
        </a>
        <a href="https://www.hackerrank.com/profile/priyanshu17ks" class="social-icon-circle" target="_blank" title="HackerRank">
          <img src="https://img.icons8.com/external-tal-revivo-color-tal-revivo/24/external-hackerrank-is-a-technology-company-that-focuses-on-competitive-programming-logo-color-tal-revivo.png" alt="HackerRank">
        </a>
        <a href="https://hub.docker.com/repositories/priyanshuksharma" class="social-icon-circle" target="_blank" title="DockerHub">
          <img src="https://img.icons8.com/color/24/docker.png" alt="DockerHub">
        </a>
        <a href="https://www.threads.com/@the_priyanshuk_sharma?xmt=AQF0BrE9l8DXFt-0GyXblooa8byQDq_e9k-x_-uj6qhgzZ0" class="social-icon-circle" target="_blank" title="Threads">
          <img src="https://th.bing.com/th/id/OIP.49vzYqePIzdOVM6E7c8z7AHaHa?o=7rm=3&rs=1&pid=ImgDetMain&o=7&rm=3" alt="Threads" width="24" height="24">
        </a>
        <a href="https://www.instagram.com/the_priyanshuk_sharma/?hl=en" class="social-icon-circle" target="_blank" title="Instagram">
          <img src="https://img.icons8.com/color/24/instagram-new.png" alt="Instagram">
        </a>
        <a href="https://x.com/itspriyanshuks" class="social-icon-circle" target="_blank" title="X (Twitter)">
          <img src="https://img.icons8.com/color/24/twitterx.png" alt="X">
        </a>
      </div>
      <div class="social-line"></div>
    </div>
  </div>
  <%- include('partials/navbar') %>
  <main>
    <%- body %>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
  <!-- Three.js -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  
  <script src="js/main.js?v=4.2"></script>
  <script src="js/projects.js"></script>
  <script src="js/futuristic-effects.js"></script>
  <script src="js/particle-system.js"></script>
  <script src="js/chatbot.js?v=3.1"></script>
  <script src="js/innovative.js"></script>
  <script src="js/github.js"></script>
  <script src="js/dock-toggle.js"></script>
  <script src="js/dock-navigation.js"></script>
  <!-- Revolutionary Liquid Metal AI Dock -->
  <div class="dock-container">
    <ul class="bottom-nav-dock" aria-label="Revolutionary Navigation">
      <li class="dock-item">
        <a href="#hero" class="nav-link dock-link" aria-label="Home" title="Home">
          <span class="dock-emoji" aria-hidden="true"><i class="fa-solid fa-house"></i></span>
        </a>
      </li>
      <li class="dock-item">
        <a href="#about" class="nav-link dock-link" aria-label="About Me" title="About Me">
          <span class="dock-emoji" aria-hidden="true"><i class="fa-solid fa-user"></i></span>
        </a>
      </li>
      <li class="dock-item">
        <a href="#education" class="nav-link dock-link" aria-label="Education" title="Education">
          <span class="dock-emoji" aria-hidden="true"><i class="fa-solid fa-graduation-cap"></i></span>
        </a>
      </li>
      <li class="dock-item">
        <a href="#experience" class="nav-link dock-link" aria-label="Experience" title="Experience">
          <span class="dock-emoji" aria-hidden="true"><i class="fa-solid fa-briefcase"></i></span>
        </a>
      </li>
      <li class="dock-item">
        <a href="#skills" class="nav-link dock-link" aria-label="Technical Skills" title="Skills">
          <span class="dock-emoji" aria-hidden="true"><i class="fa-solid fa-code"></i></span>
        </a>
      </li>
      <li class="dock-item">
        <a href="#projects" class="nav-link dock-link" aria-label="Projects" title="Projects">
          <span class="dock-emoji" aria-hidden="true"><i class="fa-solid fa-folder-open"></i></span>
        </a>
      </li>
      <li class="dock-item">
        <a href="#contact" class="nav-link dock-link" aria-label="Contact Me" title="Contact">
          <span class="dock-emoji" aria-hidden="true"><i class="fa-solid fa-paper-plane"></i></span>
        </a>
      </li>
    </ul>
  </div>

</body>
</html>
