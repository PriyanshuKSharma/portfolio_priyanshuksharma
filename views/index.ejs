<section id="projects" class="projects-section">
  <h2>Projects</h2>
  <div class="terminal-container">
    <div class="hero-console hero-project-terminal" style="max-width: 900px; margin: 0 auto; min-height: auto;">
      <div class="console-topbar">
        <div class="console-lights" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <span id="project-terminal-title">~/portfolio/featured-projects</span>
      </div>
      <div class="console-body" style="padding: 2rem;">
        <% projects.forEach((project, index) => { %>
        <div
          class="project-content <%= index === 0 ? 'active' : '' %>"
          data-index="<%= index %>"
          data-title="<%= project.title.toLowerCase().replace(/\s+/g, '-') %>"
        >
          <div class="terminal-line">
            <span class="prompt-user">priyanshu@portfolio</span><span class="prompt-symbol">:</span><span class="prompt-path">~/portfolio/<%= project.title.toLowerCase().replace(/\s+/g, '-') %></span><span class="prompt-symbol">$</span> <span class="command-text">cat README.md</span>
          </div>
          <h3><%= project.title %></h3>
          <p><%= project.description %></p>
          
          <div class="terminal-line">
            <span class="prompt-user">priyanshu@portfolio</span><span class="prompt-symbol">:</span><span class="prompt-path">~/portfolio/<%= project.title.toLowerCase().replace(/\s+/g, '-') %></span><span class="prompt-symbol">$</span> <span class="command-text">ls technologies/</span>
          </div>
          <div class="project-tags">
            <% project.tags.forEach(tag => { %>
            <span class="tag"><%= tag %></span>
            <% }) %>
          </div>
          
          <div class="terminal-line">
            <span class="prompt-user">priyanshu@portfolio</span><span class="prompt-symbol">:</span><span class="prompt-path">~/portfolio/<%= project.title.toLowerCase().replace(/\s+/g, '-') %></span><span class="prompt-symbol">$</span> <span class="command-text">open links</span>
          </div>
          <div class="project-links">
            <a href="<%= project.github %>" target="_blank">GitHub</a>
            <% if (project.demo) { %>
            <a href="<%= project.demo %>" target="_blank">Demo</a>
            <% } %>
          </div>
          
          <div class="terminal-line">
            <span class="prompt-user">priyanshu@portfolio</span><span class="prompt-symbol">:</span><span class="prompt-path">~/portfolio/<%= project.title.toLowerCase().replace(/\s+/g, '-') %></span><span class="prompt-symbol">$</span> <span class="cursor-blink"></span>
          </div>
        </div>
        <% }) %>

        <div class="terminal-controls">
          <button id="prev-project" class="terminal-btn">&lt; Prev</button>
          <span class="terminal-pagination" id="project-pagination"
            >1 / <%= projects.length %></span
          >
          <button id="next-project" class="terminal-btn">Next &gt;</button>
