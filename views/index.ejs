<section id="education" class="chronicle-section chronicle-section--education">
  <div class="chronicle-header">
    <p class="chronicle-kicker">/education.stack</p>
    <h2 class="chronicle-title glitch-text" data-text="Education Kernel">Education Kernel</h2>
    <p class="chronicle-subtitle">Academic upgrades logged as system builds and milestones.</p>
  </div>
  <div class="chronicle-grid">
    <% timeline.filter(item => item.type === 'education').forEach((item, index) => { 
      const isLive = item.period.toLowerCase().includes('present');
    %>
    <article class="chronicle-card">
      <div class="chronicle-card-header">
        <span class="chronicle-id">EDU-<%= String(index + 1).padStart(2, '0') %></span>
        <span class="chronicle-period"><%= item.period %></span>
      </div>
      <h3 class="chronicle-role"><%= item.title %></h3>
      <span class="chronicle-org"><%= item.organization %></span>
      <p class="chronicle-desc"><%- item.description %></p>
      <div class="chronicle-tags">
        <span class="chronicle-tag <%= isLive ? 'tag-live' : 'tag-archived' %>">
          <%= isLive ? 'live' : 'archived' %>
        </span>
      </div>
    </article>
    <% }) %>
  </div>
</section>

<section id="experience" class="chronicle-section chronicle-section--experience">
  <div class="chronicle-header">
    <p class="chronicle-kicker">/experience.runbook</p>
    <h2 class="chronicle-title glitch-text" data-text="Experience Runbook">Experience Runbook</h2>
    <p class="chronicle-subtitle">Internships and research as ops logs and deployed missions.</p>
  </div>
  <div class="chronicle-grid chronicle-grid--experience">
    <% timeline.filter(item => item.type === 'work').forEach((item, index) => { %>
    <article class="chronicle-card chronicle-card--experience">
      <div class="chronicle-card-header">
        <span class="chronicle-id">EXP-<%= String(index + 1).padStart(2, '0') %></span>
        <span class="chronicle-period"><%= item.period %></span>
      </div>
      <h3 class="chronicle-role"><%= item.title %></h3>
      <span class="chronicle-org"><%= item.organization %></span>
      <p class="chronicle-desc"><%- item.description %></p>
      <div class="chronicle-command">
        <span class="command-prompt">priyanshu@ops</span>
        <span class="command-sep">:</span>
        <span class="command-path">~/experience</span>
        <span class="command-sep">$</span>
        <span class="command-text">deploy --role <%= item.title.toLowerCase().replace(/\s+/g, '-') %></span>
      </div>
    </article>
    <% }) %>
  </div>
</section>

