<section id="projects" class="projects-section">
  <h2>Projects</h2>
  <div class="terminal-container">
    <div class="terminal-window">
      <div class="terminal-header">
        <div class="terminal-buttons">
          <span class="btn-close"></span>
          <span class="btn-minimize"></span>
          <span class="btn-maximize"></span>
        </div>
        <div class="terminal-title" id="project-terminal-title">
          ~/projects/storage-saas-platform
        </div>
      </div>
      <div class="terminal-body">
        <% projects.forEach((project, index) => { %>
        <div
          class="project-content <%= index === 0 ? 'active' : '' %>"
          data-index="<%= index %>"
          data-title="<%= project.title.toLowerCase().replace(/\s+/g, '-') %>"
        >
          <div class="terminal-line">
            <span class="prompt-user">priyanshu@portfolio</span><span class="prompt-symbol">:</span><span class="prompt-path">~/projects/<%= project.title.toLowerCase().replace(/\s+/g, '-') %></span><span class="prompt-symbol">$</span> <span class="command-text">cat README.md</span>
          </div>
          <h3><%= project.title %></h3>
          <p><%= project.description %></p>
          
          <div class="terminal-line">
            <span class="prompt-user">priyanshu@portfolio</span><span class="prompt-symbol">:</span><span class="prompt-path">~/projects/<%= project.title.toLowerCase().replace(/\s+/g, '-') %></span><span class="prompt-symbol">$</span> <span class="command-text">ls technologies/</span>
          </div>
          <div class="project-tags">
            <% project.tags.forEach(tag => { %>
            <span class="tag"><%= tag %></span>
            <% }) %>
          </div>
          
          <div class="terminal-line">
            <span class="prompt-user">priyanshu@portfolio</span><span class="prompt-symbol">:</span><span class="prompt-path">~/projects/<%= project.title.toLowerCase().replace(/\s+/g, '-') %></span><span class="prompt-symbol">$</span> <span class="command-text">open links</span>
          </div>
          <div class="project-links">
            <a href="<%= project.github %>" target="_blank">GitHub</a>
            <% if (project.demo) { %>
            <a href="<%= project.demo %>" target="_blank">Demo</a>
            <% } %>
          </div>
          
          <div class="terminal-line">
            <span class="prompt-user">priyanshu@portfolio</span><span class="prompt-symbol">:</span><span class="prompt-path">~/projects/<%= project.title.toLowerCase().replace(/\s+/g, '-') %></span><span class="prompt-symbol">$</span> <span class="cursor-blink"></span>
          </div>
        </div>
        <% }) %>

        <div class="terminal-controls">
          <button id="prev-project" class="terminal-btn">&lt; Prev</button>
          <span class="terminal-pagination" id="project-pagination"
            >1 / <%= projects.length %></span
          >
          <button id="next-project" class="terminal-btn">Next &gt;</button>
        </div>
      </div>
      <div class="terminal-statusbar">
        <div class="status-item">
          <span class="status-segment">NORMAL</span>
          <span>master</span>
        </div>
        <div class="status-item">
          <span>utf-8</span>
          <span>100%</span>
        </div>
      </div>
    </div>
  </div>
</section>

